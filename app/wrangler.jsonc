{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gbt-admin",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "gbt_admin",
      "database_id": "003ddb66-2dd6-4d0a-b5a6-86cc19f7bfc0",
      "migrations_dir": "drizzle"
    }
  ],
  "r2_buckets": [
    {
      "binding": "PHOTOS",
      "bucket_name": "gbt-photos"
    }
  ],
  "vars": {
    // Set both to enable real Cloudflare Access JWT verification in production.
    // Empty in dev: the identity middleware accepts the dev header instead.
    "ACCESS_TEAM_DOMAIN": "",
    "ACCESS_AUD": ""
  }
}
