{
  "name": "gbt-admin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:ui": "vite",
    "build": "vite build",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply gbt_admin --local",
    "db:migrate:remote": "wrangler d1 migrations apply gbt_admin --remote",
    "seed:dev": "wrangler d1 execute gbt_admin --local --file=./worker/db/seed-dev.sql",
    "seed:perf": "node ./worker/db/generate-perf-seed.mjs && wrangler d1 execute gbt_admin --local --file=./worker/db/seed-perf.sql",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.workers.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:perf": "PERF=1 playwright test tests/e2e/perf-directory.spec.ts"
  },
  "dependencies": {
    "@fontsource/archivo": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/public-sans": "^5.2.7",
    "@tanstack/react-query": "^5.101.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "jose": "^6.2.3",
    "lucide-react": "^1.24.0",
    "nanoid": "^5.1.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@cloudflare/workers-types": "^5.20260716.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "better-sqlite3": "^12.11.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  }
}
